{
  "language": "japanese",
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git switch *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(wget *)",
      "Bash(git push *--force*)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Bash(git remote add *)",
      "Bash(git remote set-url *)",
      "Bash(git remote remove *)",
      "Bash(npm publish *)",
      "Bash(bun publish *)",
      "Bash(pnpm publish *)",
      "Bash(yarn publish *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  }
}
